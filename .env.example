# ═══ HFT Copy-Trader: Pump.fun Quick Cycle ═══
#
# Скопируй → .env, заполни. НЕ коммить .env!

# ─── ОБЯЗАТЕЛЬНО ──────────────────────────────────────────

SOLANA_PRIVATE_KEY=
HELIUS_API_KEY=

# Можно задать свои RPC/WSS URL (например Helius Gatekeeper RPC URL beta).
# Если не задано — бот соберёт Helius RPC/WSS из HELIUS_API_KEY.
RPC_URL=
WSS_URL=
# 1 = использовать Gatekeeper RPC URL (beta.helius-rpc.com) автоматически
HELIUS_GATEKEEPER_RPC=0

# 0 = paper (логи без реальных сделок), 1 = LIVE
LIVE_TRADING=0

# ─── СТАВКА ───────────────────────────────────────────────

BUY_AMOUNT_SOL=0.012
# Шире slip = меньше отмен по движению кривой (больше риск худшего fill). Для pump часто 2200–2800.
SLIPPAGE_BPS=2500
SELL_SLIPPAGE_BPS=4000

# Priority fee (lamports). Низкие значения = чаще отсутствие включения в блок при конкуренции.
PRIORITY_FEE_LAMPORTS=800000
PRIORITY_FEE_SELL_LAMPORTS=1500000

# ─── QUICK CYCLE ──────────────────────────────────────────

# Take Profit: основной выход по кривой
TAKE_PROFIT_PCT=25

# Ранний QUICKTP: в первые 15 с выходить только если уже +X% (иначе ждём TP)
QUICKTP_MIN_PCT=22

# Stop Loss: -25% (на pump часто нужен шире; см. EARLYSL)
STOP_LOSS_PCT=25

# BREAKEVEN: выход при откате к 0 только если пик был ≥ +X%
BREAKEVEN_MIN_PEAK_PCT=30

# PROFIT_LOCK: если позиция уже дала пик ≥ X%, то не отдавать прибыль ниже FLOOR%
# 0 = отключить profit-lock (тогда останется PEAK_PULLBACK/TRAIL/BREAKEVEN)
PROFIT_LOCK_MIN_PEAK_PCT=6
PROFIT_LOCK_FLOOR_PCT=0.5

# Пик по позиции (оценка с кривой): при откате на N п.п. от максимума — SELL (анти «был в плюсе, скатился в минус»). 0 = выкл.
TRAIL_MIN_PEAK_PCT=3
PEAK_PULLBACK_PCT=5
# Классический TRAIL: закрыть если текущий pnl < пик × (значение/100), напр. 65 = оставить не ниже 65% от пикового pnl
TRAIL_REL_MULT_PCT=65

# Опционально: свои кошельки вручную (через запятую). Пусто = бот сам ищет цели по WS — ничего подбирать не нужно
COPY_WALLETS=

# 1 = авто-поиск целей (дефолт). 0 = только COPY_WALLETS
SCRAPE_AUTO_TARGETS=1

# Time-Kill: через N с если профит < MIN % — выход (на pump часто 30–40с достаточно)
TIMEKILL_SEC=35
TIMEKILL_MIN_PCT=2
# TIMEKILL не будет продавать, если pnl уже хуже этого минуса (иначе вы режете -10..-20% "по времени")
TIMEKILL_MAX_LOSS_PCT=2
# После N секунд, если pnl не достиг "чистого" порога (net exit), закрыть позицию, не дожидаясь полного SL.
# 0 = выкл.
SOFT_HARDKILL_SEC=90
# Лимит минуса для SOFTHARD/HARDKILL (не держать до полного SL). Например 10 = до -10%.
SOFT_HARDKILL_MAX_LOSS_PCT=10
# Минимальный "чистый" порог для профитных выходов (TRAIL/PEAKPB/TIMEKILL в плюсе), с учетом fixed-cost.
# 0 = авторасчёт: priority+jito+буфер.
MIN_NET_EXIT_PCT=0
NET_EXIT_BUFFER_PCT=0.5

# EARLYSL: в первые N секунд выход, если mark-to-market pnl <= -X% (шум на pump; было жёстко −8%/5с)
# EARLYSL_SEC=0 — полностью отключить ранний стоп
EARLYSL_SEC=5
EARLYSL_MIN_PCT=18

# ─── ЛИМИТЫ ──────────────────────────────────────────────

# Макс. одновременных позиций
MAX_POSITIONS=2

# Макс. целевых кошельков
MAX_TARGETS=50

# ─── СКОРОСТЬ ────────────────────────────────────────────

# Интервал скрапинга целей (минуты)
SCRAPE_INTERVAL_MIN=3

# Скрейп: минимум N покупок в один mint (same-mint), чтобы добавить цель без profit. 0 = выкл. (только profit>30% / крупный бай)
SCRAPE_SAME_MINT_MIN=5

# ─── ФИЛЬТР СИГНАЛОВ КОПИТРЕЙДИНГА ─────────────────────────
MIN_WHALE_BUY_SOL=0.65
MIN_VSR_LAMPORTS=45000000000

# ─── OBSERVE/APPROVE ───────────────────────────────────────
# Сначала наблюдаем кошельки-кандидаты, копируем только после утверждения.
OBSERVE_ONLY=0

# ─── MIGRATION SNIPER (observe сначала) ─────────────────────
# off = обычный режим (copy-trading). observe = только детект graduation (BondingCurve.Done), без торговли.
# live = пока как observe (покупка на DEX добавляется после утверждения стратегии).
MIGRATION_MODE=off
# Частота сканирования (сек). 5–15 обычно ок.
MIGRATION_SCAN_SEC=10
# Сколько свежих mint'ов проверять за цикл (через RPC readBC). Держи 20–60, чтобы не долбить RPC.
MIGRATION_MAX_CHECK=30
# Фильтр по "возрасту" mint (с момента первого появления в watcher, в RAM).
# Если задано — watcher будет выводить GRADUATED только когда mint прожил >= этого времени после firstSeen.
MIGRATION_MIN_FIRSTSEEN_AGE_SEC=0
# Если задано — отсечь случаи, где mint "тянулся" слишком долго.
MIGRATION_MAX_FIRSTSEEN_AGE_SEC=0
# Минимальный возраст кандидата перед утверждением (сек)
CAND_MIN_AGE_SEC=600
# Минимум сделок кандидата (за окно наблюдения)
CAND_MIN_TRADES=5
# Минимальная прибыль кандидата (в процентах)
CAND_MIN_PROFIT_PCT=30
# Минимальный суммарный объём покупок кандидата (SOL)
CAND_MIN_TOTAL_BUY_SOL=5
# 1 = требовать флаг "2x/24h" (жёстко, меньше кандидатов)
CAND_REQUIRE_2X24H=0

# ─── SHADOWING (Copy-Sell Exit) ─────────────────────────────
# 1 = если кошелёк-цель продал тот же mint — продаём нашу позицию сразу
COPY_SELL_EXIT=0
# Минимальный возраст позиции (сек), прежде чем разрешать copy-sell (анти гонок confirm/ATA)
COPY_SELL_MIN_AGE_SEC=3
# Опционально: не копировать продажу цели, если est_pnl по кривой хуже этого %% (как в логе [SELL] est_pnl).
# Пример: -5 = не продавать по копи-селлу при est ниже -5%%, ждать SL/монитор. Пусто = без фильтра.
# COPY_SELL_MIN_EST_PNL_PCT=-5

# ─── DIRECT PUMP COPY (самый быстрый вход) ──────────────────
# 1 = торговать напрямую по глобальному pump WS (без набора targets).
# Это позволяет заходить «сразу после него» по любому BUY, который проходит фильтр MIN_WHALE_BUY_SOL.
# Опаснее (меньше селекции целей), поэтому по умолчанию 0.
DIRECT_PUMP_COPY=0

# ─── VSR SPEED EXIT ─────────────────────────────────────────
# 1 = выходить, когда приток ликвидности (VSR) затух после прибыльного пика
VSR_SPEED_EXIT=0
# окно оценки скорости (сек)
VSR_SPEED_WINDOW_SEC=6
# если скорость прироста VSR <= этого порога (SOL/сек) — считаем, что интерес затух
VSR_SPEED_MIN_UP_SOL_PER_SEC=0.8
# включать только если пик pnl был >= этого процента
VSR_SPEED_MIN_PEAK_PNL_PCT=6
# не применять раньше этого возраста позиции (сек)
VSR_SPEED_MIN_AGE_SEC=8

# ─── PRE-SIMULATE BUY (почти atomic, меньше платных BUY FAIL) ────────────────
# 1 = перед отправкой BUY делаем simulateTransaction; если видно Custom:6000/slippage — не отправляем, а ретраим/скипаем
PRE_SIMULATE_BUY=0
# таймаут симуляции (ms)
PRE_SIM_TIMEOUT_MS=140
# не симулировать, если до MAX_SIGNAL_LAG_MS осталось меньше этого (ms)
PRE_SIM_LAG_BUDGET_MS=80

# ─── CONFIRM TIMEOUTS ───────────────────────────────────────
# Таймаут ожидания подписи BUY по RPC (сек). Меньше = быстрее освобождает MAX_POSITIONS при фантомах; при лаге RPC — 25–45.
BUY_CONFIRM_TIMEOUT_SEC=30
# Анти-скэм: если любой из top-N крупнейших token accounts (кроме bonding-curve ATA) держит ≥ X% supply — skip BUY.
# 0 = выключить проверку.
HOLDER_MAX_PCT=10
HOLDER_TOPN=20
# Быстрый режим holder-check: при ликвидности >= порога проверку концентрации холдеров пропускаем ради скорости.
# 0 = всегда проверять.
HOLDER_CHECK_MIN_VSR_LAMPORTS=80000000000
# Пауза перед повторной попыткой BUY по тому же mint после скипа/ошибки (не «возраст токена» с момента создания).
MINT_COOLDOWN_SEC=45
# Анти fresh-rug: не покупать mint, который впервые увидели в нашем WS потоке меньше N сек назад. 0 = выкл.
MINT_MIN_AGE_SEC=12
# После закрытия сделки в минус — не покупать этот mint N сек (дубль 6T7m после TIMEKILL). 0 = выкл.
MINT_LOSS_COOLDOWN_SEC=600
# После закрытия сделки в плюс — не покупать этот mint N сек (анти "второго захода"). 0 = выкл.
MINT_REBUY_COOLDOWN_AFTER_WIN_SEC=600
# Трейлинг сессии: пик PnL сессии ≥ MIN %%; при откате от пика на GIVEBACK п.п. — стоп новых BUY (сброс перезапуском). Проверка через 2с после сделок + на каждом STAT.
SESSION_TRAIL_MIN_PEAK_PCT=0.8
SESSION_TRAIL_GIVEBACK_PCT=3.5
# Circuit по trail только если сессия уже ≤ −NET_RED %% (0 = без порога; на мелком депозите иначе ловишь стоп после win+loss в одну секунду)
SESSION_TRAIL_NET_RED_PCT=1.0

# Интервал проверки позиций (миллисекунды)
MONITOR_MS=1500

# Первые N сек после входа — монитор каждые 250ms (иначе при обвале ждали бы MONITOR_MS). 0 = только при pnl>+2%
MONITOR_FAST_YOUNG_SEC=25

# FLASHSL: не раньше MIN_ENTRY_SEC после входа (анти ложный -50%% на кривой), до FLASH_SL_SEC. 0 = выкл.
FLASH_SL_MIN_ENTRY_SEC=5
FLASH_SL_SEC=15
FLASH_SL_MIN_PCT=18

# ─── ЗАЩИТА БАЛАНСА ──────────────────────────────────────

# Минимальный резерв баланса (lamports, 0.015 SOL)
MIN_BALANCE_RESERVE=15000000

# Стоп торговли: накопленный реализованный убыток (SOL) >= X% от баланса при старте бота (не сумма %% по сделкам)
MAX_SESSION_LOSS_PCT=30

# Aggressive buy-cancel if mint/token info fetch too slow
MAX_TOKENINFO_LAG_MS=500
# TTL кеша баланса в hot-path BUY (ms): меньше RPC -> ниже preSend.
WALLET_BAL_CACHE_TTL_MS=5000

# Jito HTTP sendTransaction (0/1). Если JITO_BUNDLE_BUY=1, BUY обычно идёт только через bundle; второй путь не нужен.
JITO_HTTP_SEND=0
# Региональный endpoint часто лучше по пингу; глобальный mainnet.block-engine.jito.wtf — балансировка. Лимит API: 1 req/s/IP/регион.
JITO_HTTP_URL=https://frankfurt.mainnet.block-engine.jito.wtf/api/v1/transactions
# Чаевые валидатору (lamports). При 429 — глобальный лимит Jito/облако; поднять tip или подождать.
JITO_TIP_LAMPORTS=1000000

# ─── JITO BUNDLES (Atomic-ish BUY) ──────────────────────────
# Официальный лимит Jito: 1 HTTP sendBundle/с на IP на регион (docs.jito.wtf → Rate Limits). Бот выдерживает паузу.
# 1 = отправлять BUY через sendBundle в block engine
JITO_BUNDLE_BUY=0
# Глобальный /bundles или регион (frankfurt/…); один URL, без дубля в JITO_BUNDLE_URLS
JITO_BUNDLE_URL=https://frankfurt.mainnet.block-engine.jito.wtf/api/v1/bundles
# Доп. регионы через запятую (по очереди). Лучше один ближайший регион — меньше 429. Не повторяйте тот же URL, что в JITO_BUNDLE_URL.
JITO_BUNDLE_URLS=

# При 429 от sendBundle (bundle endpoint) можно:
# - сделать паузу на N секунд (не долбить стену)
JITO_429_PAUSE_SEC=0
# - и/или попробовать fallback на Jito HTTP sendTransaction (не RPC), если bundle режется
# Важно: это не гарантирует inclusion и может быть поздним входом; по умолчанию выключено.
JITO_429_FALLBACK_JITO_HTTP=0

# ─── MULTI-WSS RACE ─────────────────────────────────────────
# Дополнительные WSS (через запятую). Бот подключится ко всем и возьмёт самый быстрый сигнал (dedup по signature).
WSS_URLS=

# ─── MIGRATION SNIPER ───────────────────────────────────────
# off|observe|live
MIGRATION_MODE=observe
MIGRATION_SCAN_SEC=10
# Для локалки обычно лучше 60-80; на VDS/быстром RPC можно 120.
MIGRATION_MAX_CHECK=60
# Фильтры по “реальному” firstSeenAge из pump WS (0 = выкл.)
MIGRATION_MIN_FIRSTSEEN_AGE_SEC=60
MIGRATION_MAX_FIRSTSEEN_AGE_SEC=900

# ─── MIGRATION LIVE SWAP (через Jupiter → маршруты включают Raydium) ──────────
# 0 = выключено (безопасно), 1 = включить реальные BUY/SELL на GRADUATED
MIGRATION_LIVE_SWAP=0
# Jupiter Swap API требует API key (https://portal.jup.ag). Без ключа swap будет отключён.
JUPITER_API_KEY=
# База Jupiter Swap API (metis, assembled tx)
JUPITER_BASE_URLS=https://api.jup.ag/swap/v1

# One-shot self-test (лучше задавать разово при запуске, не хранить в .env):
# SWAP_SELFTEST=1
# SWAP_SELFTEST_SOL=0.001

# Retries bonding curve / порог «плохого входа» (см. INIT лог)
BC_RETRY_MAX=12
BC_RETRY_SLEEP_MS=100
BC_SIGNAL_LAG_BUFFER_MS=100
BAD_ENTRY_PCT=20
# Если подтверждён BUY и скорр. токенов ≤ -X% (очень плохой fill) — закрыть позицию сразу.
# 0 = выключить
BAD_ENTRY_IMMEDIATE_SELL_PCT=8
BAD_ENTRY_IMMEDIATE_MIN_AGE_SEC=2
# При плохом входе (скорр. токенов) — полный SL раньше. 0 = как STOP_LOSS_PCT
BAD_ENTRY_SL_PCT=14
BAD_EXIT_FAST_SEC=4
BAD_ENTRY_FLASH_MIN_PCT=10
# Мин. Buy по mint с глобального pump WS за окно (анти «тихий» токен). 0 = выкл.
MIN_MINT_PUMP_BUYS=2
MIN_MINT_PUMP_BUYS_WINDOW_SEC=12

# ─── PIN PROFIT WALLETS (persist across restarts) ─────────
# Если по кошельку закрыли сделку в плюс ≥ X% — закрепить кошелёк и всегда держать его в целях.
# 0 = выключить автопин.
PIN_WALLET_MIN_PNL_PCT=8
# Файл со списком pinned кошельков (по одному адресу в строке)
PIN_WALLETS_FILE=pinned_wallets.txt
# Если закреплённый кошелёк дал N убыточных закрытий подряд — удалить из pinned списка (0 = не чистить автоматически)
PIN_UNPIN_AFTER_LOSSES=2
