# ═══ HFT Copy-Trader: Pump.fun Quick Cycle ═══
#
# Скопируй → .env, заполни. НЕ коммить .env!

# ─── ОБЯЗАТЕЛЬНО ──────────────────────────────────────────

SOLANA_PRIVATE_KEY=
HELIUS_API_KEY=

# 0 = paper (логи без реальных сделок), 1 = LIVE
LIVE_TRADING=0

# ─── СТАВКА ───────────────────────────────────────────────

BUY_AMOUNT_SOL=0.005
SLIPPAGE_BPS=2000
PRIORITY_FEE_LAMPORTS=100000

# ─── QUICK CYCLE ──────────────────────────────────────────

# Take Profit: +40%
TAKE_PROFIT_PCT=40

# Stop Loss: -20%
STOP_LOSS_PCT=20

# Time-Kill: если через N секунд профит < M% — выход
TIMEKILL_SEC=45
TIMEKILL_MIN_PCT=5

# ─── ЛИМИТЫ ──────────────────────────────────────────────

# Макс. одновременных позиций (не блокировать баланс)
MAX_POSITIONS=5

# Макс. целевых кошельков
MAX_TARGETS=20

# ─── СКОРОСТЬ ────────────────────────────────────────────

# Интервал скрапинга целей (минуты)
SCRAPE_INTERVAL_MIN=5

# Интервал проверки позиций (миллисекунды)
MONITOR_MS=2000
