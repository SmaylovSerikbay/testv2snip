# Скопируй этот файл как ".env" в ту же папку, где лежит бот, и заполни.
# Файл ".env" не коммить в git — там секреты.
#
# Как получить ключ Phantom:
#   Настройки → нужный аккаунт → ⋮ → Export Private Key → вставь ОДНУ base58-строку.
#
# Бумажный режим (без реальных сделок):
LIVE_TRADING=0
# Боевой mainnet (реальные SOL только через Pump.fun кривую; LaunchLab в live не торгуется):
# LIVE_TRADING=1

# Прямой Pump.fun (buy/sell на кривой): раздельное проскальзывание и приоритет
# PUMP_BUY_SLIPPAGE_BPS=3000
# PUMP_SELL_SLIPPAGE_BPS=4000
# PRIORITY_FEE_LAMPORTS=900000
# Ограничение приоритета как доля от размера сделки (в bps). 100 = 1.0%
# PUMP_PRIORITY_MAX_FEE_BPS=100
# Опционально для ultra-low latency: Jito Block Engine (sendBundle). Если пусто — обычный RPC sendTransaction.
# JITO_BLOCK_ENGINE_URL=https://mainnet.block-engine.jito.wtf/api/v1/bundles
# Горячий buy-путь без лишних pre-check RPC (default ON). Выключить: HOT_PATH_FAST_BUY=0
# HOT_PATH_FAST_BUY=1
# Тишина в hot-path (default ON): без логов между detect и send. Выключить: HOT_PATH_SILENT=0
# HOT_PATH_SILENT=1
# Продажа: min_sol_out=1 по умолчанию (снимает 6024 Overflow). Выключить «жёсткий» min: PUMP_SELL_MIN_SOL_ONE=false

# Обязательно при LIVE_TRADING=1:
# SOLANA_PRIVATE_KEY=твоя_base58_строка_без_кавычек_и_пробелов

# Профиль фильтра сигналов:
# strict — максимально чисто, мало входов
# balanced — баланс (по умолчанию)
# aggressive — больше входов, но больше шума
# SIGNAL_PROFILE=balanced
# Влияние на анти-скам:
# strict: жёстче (dev SOL выше, доля в кривой выше, вне кривой ниже)
# aggressive: мягче (чуть больше поток, но риск выше)

# Чтобы за полчаса «поймать» хоть что-то для проверки пайплайна (очень шумно, не рекомендуется):
# SKIP_VELOCITY=1
# SKIP_ANTI_SCAM=1
