# ═══ HFT Copy-Trader: Pump.fun Quick Cycle ═══
#
# Скопируй → .env, заполни. НЕ коммить .env!

# ─── ОБЯЗАТЕЛЬНО ──────────────────────────────────────────

SOLANA_PRIVATE_KEY=
HELIUS_API_KEY=

# 0 = paper (логи без реальных сделок), 1 = LIVE
LIVE_TRADING=0

# ─── СТАВКА ───────────────────────────────────────────────

BUY_AMOUNT_SOL=0.003
SLIPPAGE_BPS=2000
PRIORITY_FEE_LAMPORTS=80000

# ─── QUICK CYCLE ──────────────────────────────────────────

# Take Profit: +30%
TAKE_PROFIT_PCT=30

# Stop Loss: -10% (жёстко режем убытки)
STOP_LOSS_PCT=10

# Time-Kill: если через 15 секунд профит < 3% — выход
TIMEKILL_SEC=15
TIMEKILL_MIN_PCT=3

# ─── ЛИМИТЫ ──────────────────────────────────────────────

# Макс. одновременных позиций
MAX_POSITIONS=2

# Макс. целевых кошельков
MAX_TARGETS=20

# ─── СКОРОСТЬ ────────────────────────────────────────────

# Интервал скрапинга целей (минуты)
SCRAPE_INTERVAL_MIN=2

# Интервал проверки позиций (миллисекунды)
MONITOR_MS=1500
